# Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Models Configuration
PRIMARY_MODEL=gemini-flash-latest
FALLBACK_MODEL=gemini-2.5-flash
# Embedding Configuration
# EMBEDDING_PROVIDER: "local" (free, fast, no rate limits, runs locally using sentence-transformers, recommended for normal/low traffic/demos)
#                     or "google" (for high-traffic production once paid Gemini API tier is active — higher quality, billed per use, rate-limited on free tier)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Document Processing Settings
MAX_FILE_SIZE_MB=10
PARENT_CHUNK_SIZE=2000
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=500
CHILD_CHUNK_OVERLAP=50

# Storage
VECTOR_STORE_PATH=vector_store
